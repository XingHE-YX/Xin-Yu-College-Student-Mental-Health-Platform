.screen {
  position: relative;
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.screen__stack {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.surface-card {
  background: #ffffff;
  border: 2rpx solid #e3eae7;
  border-radius: 40rpx;
  padding: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(18, 63, 58, 0.08);
  box-sizing: border-box;
}

.surface-card--soft {
  background: linear-gradient(180deg, #ffffff 0%, #f8fbfa 100%);
}

.surface-card--warm {
  background: linear-gradient(180deg, #fff8f1 0%, #ffffff 100%);
}

.surface-card--muted {
  background: #f8fafa;
}

.eyebrow {
  font-size: 24rpx;
  line-height: 1.4;
  color: #2f8f83;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.section-title {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.3;
  color: #1f2a28;
}

.section-subtitle {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.3;
  color: #123f3a;
}

.body-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #41504c;
}

.helper-text {
  font-size: 26rpx;
  line-height: 1.5;
  color: #70807c;
}

.caption-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #70807c;
}

.status-banner {
  border-radius: 28rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.status-banner--error {
  background: #fbe7e7;
  color: #a92a2a;
}

.status-banner--warning {
  background: #fff3df;
  color: #a86a14;
}

.status-banner--success {
  background: #e9f6ed;
  color: #2f7d49;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field__label {
  font-size: 28rpx;
  line-height: 1.5;
  color: #41504c;
}

.field__input {
  min-height: 96rpx;
  padding: 0 28rpx;
  border-radius: 28rpx;
  border: 2rpx solid #d7e1de;
  background: #ffffff;
  color: #1f2a28;
  font-size: 30rpx;
  box-sizing: border-box;
}

.field__input--error {
  border-color: #d84c4c;
}

.field__hint {
  font-size: 24rpx;
  line-height: 1.5;
  color: #70807c;
}

.inline-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.inline-list__item {
  font-size: 28rpx;
  line-height: 1.6;
  color: #41504c;
}

.button-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.module-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.module-card {
  background: #ffffff;
  border-radius: 36rpx;
  padding: 28rpx;
  border: 2rpx solid #e3eae7;
  box-shadow: 0 12rpx 36rpx rgba(18, 63, 58, 0.06);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.module-card--disabled {
  background: #f8fafa;
}

.module-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.module-card__title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.3;
  color: #1f2a28;
}

.module-card__meta {
  min-width: 120rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef7f5;
  color: #1e645c;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
  box-sizing: border-box;
}

.module-card__meta--warning {
  background: #fff3df;
  color: #a86a14;
}

.module-card__meta--disabled {
  background: #eef2f1;
  color: #70807c;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef7f5;
  color: #1e645c;
  font-size: 24rpx;
  line-height: 1.4;
}

.chip--warm {
  background: #fff1e3;
  color: #b8691e;
}

.chip--muted {
  background: #eef2f1;
  color: #70807c;
}
