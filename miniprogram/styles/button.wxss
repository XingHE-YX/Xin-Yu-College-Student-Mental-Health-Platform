.btn-base {
  min-height: 92rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
  padding: 0 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 160ms ease, opacity 160ms ease;
}

.btn-base::after {
  border: none;
}

.btn-base--primary {
  background: linear-gradient(135deg, #2d7c84 0%, #4f9ebd 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(45, 124, 132, 0.24);
}

.btn-base--secondary {
  background: #eef4f3;
  color: #185b62;
  border: 2rpx solid rgba(217, 228, 227, 0.92);
}

.btn-base--danger {
  background: #d84c4c;
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(216, 76, 76, 0.2);
}

.btn-base[disabled] {
  background: #e6ecea;
  color: #98a4a1;
  border-color: transparent;
  box-shadow: none;
}
