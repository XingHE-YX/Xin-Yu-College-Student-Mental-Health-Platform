@import "../../styles/page.wxss";

.startup-screen {
  display: flex;
  align-items: center;
}

.startup-screen__stack {
  width: 100%;
}

.startup-status {
  align-items: center;
  text-align: center;
}

.startup-status__spinner {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(47, 143, 131, 0.12);
  border-top-color: #2f8f83;
  animation: startup-spin 1s linear infinite;
}

@keyframes startup-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
