<app-shell>
  <view class="channel-screen">
    <view class="channel-screen__stack">
      <channel-header
        eyebrow="Assessment"
        title="测评"
        summary="把五份问卷整理成一条清晰的任务主线。先完成必做 70 题，再决定是否补充 UPI 辅助筛查。"
      >
        <view slot="side" class="channel-identity">
          <view class="channel-identity__name">{{student.display_nickname}}</view>
          <view class="channel-identity__summary">{{student.college_name}}</view>
        </view>
      </channel-header>

      <view wx:if="{{consentDeclined}}" class="status-banner status-banner--warning">
        你当前拒绝了危机干预授权。树洞频道会保持禁用，但测评和报告链路不受影响。
      </view>

      <content-section-card tone="soft">
        <view class="channel-page-card__head">
          <view>
            <view class="eyebrow">主线进度</view>
            <view class="section-subtitle">{{progressHeadline}}</view>
          </view>
          <view class="chip {{requiredProgress.full_profile_unlocked ? 'chip--success' : 'chip--muted'}}">
            {{requiredProgress.full_profile_unlocked ? '已解锁' : '未解锁'}}
          </view>
        </view>
        <view class="body-text">{{progressSummary}}</view>
        <view class="chip-row home-page__chip-row">
          <view class="chip">必做 {{requiredProgress.completed_required_questionnaires}} / {{requiredProgress.total_required_questionnaires}}</view>
          <view class="chip chip--muted">{{requiredProgress.completed_required_questions}} / {{requiredProgress.total_required_questions}} 题</view>
          <view class="chip {{student.consent_status === 'granted' ? '' : 'chip--warm'}}">
            {{student.consent_status === 'granted' ? '授权已完成' : '授权已拒绝'}}
          </view>
        </view>
        <view class="home-page__progress">
          <progress-bar
            label="70 题主线"
            current="{{requiredProgress.completed_required_questions}}"
            total="{{requiredProgress.total_required_questions}}"
          ></progress-bar>
        </view>
        <view wx:if="{{missingRequiredNames.length}}" class="home-page__missing">
          <view class="helper-text">剩余必做问卷</view>
          <view class="chip-row">
            <view wx:for="{{missingRequiredNames}}" wx:key="*this" class="chip chip--muted">
              {{item}}
            </view>
          </view>
        </view>
      </content-section-card>

      <content-section-card tone="default" eyebrow="Quick Actions" title="现在可以直接去做">
        <quick-action-row items="{{quickActions}}" bind:action="handleQuickAction" />
      </content-section-card>

      <block wx:if="{{dashboardError}}">
        <view class="status-banner status-banner--error">{{dashboardError}}</view>
        <view class="button-stack home-page__retry">
          <secondary-button label="重新加载问卷目录" bind:tap="handleRetryTap" />
        </view>
      </block>

      <content-section-card
        tone="default"
        eyebrow="Required Track"
        title="必做主线"
        summary="这四份问卷共同决定完整报告是否解锁。建议按当前顺序连续完成。"
      >
        <view wx:if="{{loadingDashboard}}" class="helper-text">正在同步主线问卷目录与当前进度...</view>
        <view wx:elif="{{requiredCards.length}}" class="module-grid">
          <view
            wx:for="{{requiredCards}}"
            wx:key="code"
            class="module-card"
            data-code="{{item.code}}"
            bindtap="handleQuestionnaireTap"
          >
            <view class="module-card__head">
              <view>
                <view class="module-card__title">{{item.name}}</view>
                <view class="helper-text">{{item.flowStepLabel}} · {{item.badge}}</view>
              </view>
              <view class="module-card__meta {{item.stateTone === 'success' ? 'module-card__meta--success' : ''}} {{item.stateTone === 'warning' ? 'module-card__meta--warning' : ''}}">
                {{item.stateLabel}}
              </view>
            </view>
            <view class="chip-row">
              <view class="chip">{{item.questionCountLabel}}</view>
              <view class="chip chip--warm">{{item.chainLabel}}</view>
            </view>
            <view class="body-text">{{item.summary}}</view>
            <view wx:if="{{item.latestResultLabel}}" class="chip-row">
              <view class="chip {{item.latestResultTone}}">{{item.latestResultLabel}}</view>
            </view>
            <view class="helper-text">{{item.helper}}</view>
          </view>
        </view>
      </content-section-card>

      <content-section-card
        tone="warm"
        eyebrow="Optional"
        title="辅助筛查"
        summary="可选问卷不会阻塞完整报告解锁，但可以为综合判断补充风险信号。"
      >
        <view wx:if="{{optionalCards.length}}" class="module-grid">
          <view
            wx:for="{{optionalCards}}"
            wx:key="code"
            class="module-card"
            data-code="{{item.code}}"
            bindtap="handleQuestionnaireTap"
          >
            <view class="module-card__head">
              <view>
                <view class="module-card__title">{{item.name}}</view>
                <view class="helper-text">{{item.flowStepLabel}} · {{item.badge}}</view>
              </view>
              <view class="module-card__meta {{item.stateTone === 'success' ? 'module-card__meta--success' : ''}}">
                {{item.stateLabel}}
              </view>
            </view>
            <view class="chip-row">
              <view class="chip chip--warm">{{item.questionCountLabel}}</view>
              <view class="chip chip--muted">{{item.chainLabel}}</view>
            </view>
            <view class="body-text">{{item.summary}}</view>
            <view wx:if="{{item.latestResultLabel}}" class="chip-row">
              <view class="chip {{item.latestResultTone}}">{{item.latestResultLabel}}</view>
            </view>
            <view class="helper-text">{{item.helper}}</view>
          </view>
        </view>
      </content-section-card>
    </view>
  </view>

  <floating-tab-bar activeKey="assessment" bind:change="handleChannelChange" />
</app-shell>
