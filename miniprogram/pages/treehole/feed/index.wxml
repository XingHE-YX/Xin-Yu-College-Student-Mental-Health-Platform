<app-shell>
  <view class="channel-screen">
    <view class="channel-screen__stack">
      <channel-header
        eyebrow="Treehole"
        title="树洞"
        summary="一个只展示匿名昵称、脱敏正文和预设支持反馈的公开广场。你可以浏览内容流，也可以写下一条自己的心情。"
      >
        <view slot="side" class="treehole-page__header-side">
          <view class="treehole-page__header-pill">{{feedDisabled ? '未开放' : '可发布'}}</view>
        </view>
      </channel-header>

      <view wx:if="{{feedDisabled}}" class="status-banner status-banner--warning">
        你尚未开放危机干预授权，因此当前不能进入树洞发布链路。
      </view>

      <view wx:if="{{deleteNotice}}" class="status-banner status-banner--success">
        {{deleteNotice}}
      </view>

      <content-section-card tone="soft">
        <view class="channel-page-card__head">
          <view>
            <view class="eyebrow">频道摘要</view>
            <view class="section-subtitle">公开内容流</view>
          </view>
        </view>
        <view class="body-text">{{feedSummary}}</view>
        <view class="metrics-grid treehole-page__metrics-grid">
          <view class="metric-panel">
            <view class="metric-panel__label">公开帖子</view>
            <view class="metric-panel__value">{{metrics.publicCount}}</view>
            <view class="metric-panel__summary">仅展示允许公开发布的内容</view>
          </view>
          <view class="metric-panel">
            <view class="metric-panel__label">我的帖子</view>
            <view class="metric-panel__value">{{metrics.myCount}}</view>
            <view class="metric-panel__summary">可进入详情查看完整内容或删除</view>
          </view>
          <view class="metric-panel">
            <view class="metric-panel__label">支持反馈</view>
            <view class="metric-panel__value">{{metrics.supportCount}}</view>
            <view class="metric-panel__summary">只保留抱抱、点亮、陪伴三种反馈</view>
          </view>
          <view class="metric-panel">
            <view class="metric-panel__label">当前状态</view>
            <view class="metric-panel__value metric-panel__value--sm">
              {{feedDisabled ? '受限' : '开放'}}
            </view>
            <view class="metric-panel__summary">
              {{feedDisabled ? '授权后可恢复发布能力' : '可以继续写下一条匿名心情'}}
            </view>
          </view>
        </view>
      </content-section-card>

      <view wx:if="{{loadError}}" class="status-banner status-banner--error">{{loadError}}</view>

      <block wx:if="{{feedDisabled}}">
        <content-section-card
          tone="warm"
          eyebrow="当前不可用"
          title="树洞频道已暂时关闭"
          summary="拒绝授权不会影响测评和报告。如果之后需要恢复树洞能力，可在后续版本重新提交授权决策。"
        >
          <view class="button-stack treehole-page__actions">
            <secondary-button label="返回测评频道" bind:tap="handleBackHome" />
          </view>
        </content-section-card>
      </block>

      <block wx:else>
        <view wx:if="{{loading}}" class="channel-page-card channel-page-card--default">
          <view class="eyebrow">加载中</view>
          <view class="section-subtitle">正在同步树洞广场</view>
          <view class="body-text">请稍候，系统正在加载已公开的匿名内容与最新互动状态。</view>
        </view>

        <view wx:elif="{{posts.length}}" class="treehole-page__feed-list">
          <treehole-post-card
            wx:for="{{posts}}"
            wx:key="postId"
            anonymousName="{{item.anonymousName}}"
            anonymousAvatarKey="{{item.anonymousAvatarKey}}"
            relativeTime="{{item.relativeTime}}"
            content="{{item.content}}"
          >
            <view slot="head-extra" class="chip-row">
              <view wx:if="{{item.isMine}}" class="chip">我的帖子</view>
              <view class="chip chip--muted">{{item.totalReactionCount}} 条支持</view>
            </view>

            <view class="treehole-page__reaction-row">
              <reaction-chip
                wx:for="{{item.reactions}}"
                wx:for-item="reaction"
                wx:key="reactionType"
                label="{{reaction.label}}"
                count="{{reaction.count}}"
                active="{{reaction.reactedByMe}}"
                disabled="{{reaction.busy}}"
                data-post-id="{{item.postId}}"
                data-reaction-type="{{reaction.reactionType}}"
                bind:tap="handleReactionTap"
              />
            </view>

            <view class="treehole-page__post-foot">
              <view class="helper-text">
                {{item.isMine ? '这条帖子来自你自己。可进入详情查看完整内容并执行删除。' : '当前支持通过预设反馈表达关心。'}}
              </view>
              <view
                class="treehole-page__detail-link"
                data-post-id="{{item.postId}}"
                bindtap="handlePostTap"
              >
                {{item.detailLinkLabel}}
              </view>
            </view>
          </treehole-post-card>
        </view>

        <content-section-card
          wx:elif="{{!loadError}}"
          tone="warm"
          eyebrow="空状态"
          title="广场还没有公开帖子"
          summary="你可以先发布一条自己的匿名心情。公开前系统会自动隐藏手机号和邮箱等明显联系方式。"
        >
          <view class="button-stack">
            <primary-button label="写下第一条树洞" bind:tap="handleCreateTap" />
          </view>
        </content-section-card>

        <view wx:if="{{loadError}}" class="button-stack">
          <secondary-button label="重新加载广场" bind:tap="handleRetryLoad" />
        </view>

        <view class="sticky-primary-action">
          <primary-button label="发布一条匿名心情" bind:tap="handleCreateTap" />
        </view>
      </block>
    </view>
  </view>

  <floating-tab-bar activeKey="treehole" bind:change="handleChannelChange" />
</app-shell>
