<app-shell>
  <view class="screen">
    <view class="screen__stack">
      <hero-card
        eyebrow="S16 Treehole Detail"
        title="{{heroTitle}}"
        summary="{{heroSummary}}"
        tone="{{heroTone}}"
      />

      <view wx:if="{{statusMessage}}" class="status-banner status-banner--success">
        {{statusMessage}}
      </view>

      <view wx:if="{{loading}}" class="surface-card">
        <view class="eyebrow">加载中</view>
        <view class="section-subtitle">正在同步帖子详情</view>
        <view class="body-text">请稍候，系统正在读取这条匿名帖子的完整内容与当前支持反馈。</view>
      </view>

      <block wx:elif="{{loadError}}">
        <view class="status-banner status-banner--error">{{loadError}}</view>
        <view class="button-stack">
          <secondary-button label="重新加载帖子详情" bind:tap="handleRetryLoad" />
          <secondary-button label="返回广场" bind:tap="handleBackToFeed" />
        </view>
      </block>

      <block wx:elif="{{!post}}">
        <view class="surface-card surface-card--warm">
          <view class="treehole-page__empty-state">
            <view class="treehole-page__empty-mark">匿</view>
            <view class="section-subtitle">当前找不到这条帖子了</view>
            <view class="body-text">
              它可能已经从公开广场移除，或者当前会话中没有可用的详情缓存。你可以先返回广场继续浏览。
            </view>
          </view>
        </view>
        <view class="button-stack">
          <secondary-button label="返回广场" bind:tap="handleBackToFeed" />
        </view>
      </block>

      <block wx:elif="{{post.publishStatus === 'deleted_by_user'}}">
        <view class="surface-card surface-card--warm">
          <view class="eyebrow">删除已完成</view>
          <view class="section-subtitle">这条帖子已经从学生端移除</view>
          <view class="body-text">
            删除采用软删除方式：广场和学生端详情不再公开显示这条内容，但后台仍会保留记录，用于后续审计与复核。
          </view>
          <view class="chip-row treehole-page__detail-meta">
            <view class="chip chip--muted">{{post.deletedAtChipLabel}}</view>
            <view class="chip chip--warm">后台仍保留记录</view>
          </view>
        </view>

        <view class="button-stack">
          <secondary-button label="返回广场" bind:tap="handleBackToFeed" />
        </view>
      </block>

      <block wx:else>
        <treehole-post-card
          anonymousName="{{post.anonymousName}}"
          anonymousAvatarKey="{{post.anonymousAvatarKey}}"
          relativeTime="{{post.relativeTime}}"
          content="{{post.content}}"
          fullContent="{{true}}"
        >
          <view slot="head-extra" class="chip-row">
            <view wx:if="{{post.isMine}}" class="chip">我的帖子</view>
            <view class="chip {{post.publishStatus === 'published' ? 'chip--success' : 'chip--muted'}}">
              {{post.publishStatusLabel}}
            </view>
          </view>

          <view class="treehole-page__detail-meta">
            <view class="chip chip--muted">{{post.publishedAtLabel}}</view>
            <view class="chip chip--warm">{{post.totalReactionCount}} 条支持</view>
          </view>
        </treehole-post-card>

        <view class="surface-card surface-card--soft">
          <view class="eyebrow">支持反馈</view>
          <view class="body-text treehole-page__support-note">
            {{post.isMine ? '这里展示的是其他同学在广场里留下的预设支持反馈。' : '当前阶段只开放预设互动，不开放评论、私信和联系方式交换。'}}
          </view>
          <view class="treehole-page__reaction-row">
            <reaction-chip
              wx:for="{{post.reactions}}"
              wx:key="reactionType"
              label="{{item.label}}"
              count="{{item.count}}"
              active="{{item.reactedByMe}}"
              disabled="{{true}}"
            />
          </view>
        </view>

        <view wx:if="{{post.isMine && post.publishStatus === 'published'}}" class="surface-card surface-card--warm">
          <view class="eyebrow">删除说明</view>
          <view class="section-subtitle">删除后，这条帖子会从学生端广场中消失</view>
          <view class="body-text">
            删除采用软删除方式：学生端将不再显示这条帖子，但后台仍会保留记录以满足审计与复核需要。
          </view>
        </view>

        <view class="button-stack">
          <danger-button
            wx:if="{{post.isMine && post.publishStatus === 'published'}}"
            label="删除这条帖子"
            loading="{{deleting}}"
            bind:tap="handleDeleteTap"
          />
          <secondary-button
            label="返回广场"
            disabled="{{deleting}}"
            bind:tap="handleBackToFeed"
          />
        </view>
      </block>
    </view>
  </view>

  <confirm-modal
    visible="{{showDeleteConfirm}}"
    title="确认删除这条帖子？"
    message="删除后，这条内容会从学生端广场中消失，但后台仍会保留记录。这个操作无法在当前阶段恢复。"
    confirmText="确认删除"
    cancelText="暂不删除"
    bind:cancel="handleDeleteCancel"
    bind:confirm="handleDeleteConfirm"
  />
</app-shell>
