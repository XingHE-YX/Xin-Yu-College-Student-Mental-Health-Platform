.confirm-modal {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 90;
}

.confirm-modal__mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(18, 42, 40, 0.32);
}

.confirm-modal__panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #ffffff;
  border-radius: 36rpx;
  border-top: 8rpx solid #d84c4c;
  padding: 40rpx 32rpx 32rpx;
  box-shadow: 0 28rpx 72rpx rgba(18, 63, 58, 0.16);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.confirm-modal__title {
  font-size: 40rpx;
  font-weight: 600;
  line-height: 1.3;
  color: #a92a2a;
}

.confirm-modal__message {
  font-size: 28rpx;
  line-height: 1.6;
  color: #41585b;
}

.confirm-modal__actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.confirm-modal__button {
  min-height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  line-height: 1.4;
}

.confirm-modal__button::after {
  border: none;
}

.confirm-modal__button--ghost {
  background: #eef4f3;
  color: #185b62;
}

.confirm-modal__button--danger {
  background: #d84c4c;
  color: #ffffff;
}
