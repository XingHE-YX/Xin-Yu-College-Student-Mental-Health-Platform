.app-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(143, 201, 189, 0.26), transparent 38%),
    radial-gradient(circle at top right, rgba(247, 197, 138, 0.18), transparent 34%),
    linear-gradient(180deg, #eef7f5 0%, #f8fafa 42%, #ffffff 100%);
}

.app-shell--padded {
  padding-bottom: 32rpx;
}

.app-shell__safe {
  position: relative;
  z-index: 2;
  min-height: 100vh;
}

.app-shell__mist {
  position: absolute;
  border-radius: 999rpx;
  opacity: 0.8;
}

.app-shell__mist--brand {
  top: 80rpx;
  right: -80rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(143, 201, 189, 0.24);
}

.app-shell__mist--warm {
  bottom: 120rpx;
  left: -100rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(247, 197, 138, 0.18);
}
