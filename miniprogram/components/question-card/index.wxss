.question-card {
  background: #ffffff;
  border-radius: 40rpx;
  padding: 40rpx;
  border: 2rpx solid #e3eae7;
  box-shadow: 0 16rpx 48rpx rgba(18, 63, 58, 0.08);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.question-card__badge {
  align-self: flex-start;
  min-width: 88rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #d7ece6;
  color: #1e645c;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
  box-sizing: border-box;
}

.question-card__title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.3;
  color: #1f2a28;
}

.question-card__description {
  font-size: 28rpx;
  line-height: 1.5;
  color: #70807c;
}

.question-card__body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
