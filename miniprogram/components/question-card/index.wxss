.question-card {
  background: #ffffff;
  border-radius: 34rpx;
  padding: 34rpx;
  border: 2rpx solid rgba(217, 228, 227, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(18, 63, 58, 0.08);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.question-card__badge {
  align-self: flex-start;
  min-width: 88rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf4f2;
  color: #185b62;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
  box-sizing: border-box;
}

.question-card__title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.3;
  color: #1f3436;
}

.question-card__description {
  font-size: 26rpx;
  line-height: 1.5;
  color: #7a8a8c;
}

.question-card__body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
