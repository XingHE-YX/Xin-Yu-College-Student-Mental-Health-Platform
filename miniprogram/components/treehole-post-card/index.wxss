.treehole-post-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  padding: 30rpx;
  border: 2rpx solid rgba(217, 228, 227, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(18, 63, 58, 0.08);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.treehole-post-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.treehole-post-card__profile {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

.treehole-post-card__avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #123f3a;
  flex-shrink: 0;
}

.treehole-post-card__avatar--brand {
  background: linear-gradient(135deg, #d7edf1 0%, #edf4f2 100%);
}

.treehole-post-card__avatar--warm {
  background: linear-gradient(135deg, #fff1e3 0%, #fff8f1 100%);
  color: #b8691e;
}

.treehole-post-card__avatar--deep {
  background: linear-gradient(135deg, #dbe9ea 0%, #eef2f1 100%);
  color: #185b62;
}

.treehole-post-card__avatar--mist {
  background: linear-gradient(135deg, #edf3f2 0%, #f8fafa 100%);
  color: #41504c;
}

.treehole-post-card__meta {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.treehole-post-card__name {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  color: #1f3436;
}

.treehole-post-card__time {
  font-size: 24rpx;
  line-height: 1.4;
  color: #7a8a8c;
}

.treehole-post-card__content {
  font-size: 28rpx;
  line-height: 1.7;
  color: #41585b;
  white-space: pre-wrap;
  word-break: break-word;
}

.treehole-post-card__content--clamped {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 6;
}
