.content-section-card {
  border-radius: 36rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(217, 228, 227, 0.92);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 44rpx rgba(18, 63, 58, 0.08);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  box-sizing: border-box;
}

.content-section-card--soft {
  background: linear-gradient(180deg, #ffffff 0%, #f8fbfb 100%);
}

.content-section-card--warm {
  background: linear-gradient(180deg, #fff8f1 0%, #ffffff 100%);
}

.content-section-card--muted {
  background: rgba(248, 250, 250, 0.96);
}

.content-section-card__eyebrow {
  font-size: 22rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #2d7c84;
  text-transform: uppercase;
}

.content-section-card__title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 600;
  color: #1f3436;
}

.content-section-card__summary {
  font-size: 28rpx;
  line-height: 1.6;
  color: #41585b;
}
