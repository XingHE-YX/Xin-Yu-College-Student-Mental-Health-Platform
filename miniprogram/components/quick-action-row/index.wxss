.quick-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.quick-action-row__item {
  min-height: 148rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbfb 100%);
  border: 2rpx solid rgba(217, 228, 227, 0.92);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16rpx;
}

.quick-action-row__badge {
  align-self: flex-start;
  min-width: 56rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #edf1f1;
  color: #185b62;
  font-size: 24rpx;
  line-height: 56rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
}

.quick-action-row__text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.quick-action-row__title {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 600;
  color: #1f3436;
}

.quick-action-row__summary {
  font-size: 24rpx;
  line-height: 1.5;
  color: #7a8a8c;
}
