.reaction-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(217, 228, 227, 0.92);
  background: #ffffff;
  color: #185b62;
  font-size: 24rpx;
  line-height: 1.4;
  box-sizing: border-box;
}

.reaction-chip--active {
  background: #edf4f2;
  border-color: #8ebed0;
}

.reaction-chip--disabled {
  background: #f8fafa;
  color: #98a4a1;
  border-color: #e6ecea;
}

.reaction-chip__count {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
}
