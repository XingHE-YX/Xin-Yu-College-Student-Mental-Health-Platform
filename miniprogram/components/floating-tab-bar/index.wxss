.floating-tab-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  z-index: 48;
}

.floating-tab-bar__shell {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(217, 228, 227, 0.92);
  box-shadow: 0 18rpx 44rpx rgba(18, 63, 58, 0.12);
  backdrop-filter: blur(18rpx);
}

.floating-tab-bar__item {
  flex: 1 1 0;
  min-height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  color: #6f7f82;
  transition: all 180ms ease;
  box-sizing: border-box;
}

.floating-tab-bar__item--active {
  background: #3a86c8;
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(58, 134, 200, 0.28);
}

.floating-tab-bar__label {
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 600;
  white-space: nowrap;
}
