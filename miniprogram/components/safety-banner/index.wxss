.safety-banner {
  background: #ffffff;
  border-top: 8rpx solid #d84c4c;
  border-radius: 36rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(18, 63, 58, 0.14);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.safety-banner__title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.3;
  color: #a92a2a;
}

.safety-banner__message {
  font-size: 26rpx;
  line-height: 1.6;
  color: #41585b;
}

.safety-banner__hotline {
  font-size: 26rpx;
  line-height: 1.5;
  color: #a92a2a;
}
