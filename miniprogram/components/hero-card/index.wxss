.hero-card {
  position: relative;
  overflow: hidden;
  border-radius: 40rpx;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 48rpx rgba(18, 63, 58, 0.1);
}

.hero-card--brand {
  background: linear-gradient(160deg, #ffffff 0%, #eef7f5 55%, #d7ece6 100%);
}

.hero-card--warm {
  background: linear-gradient(160deg, #ffffff 0%, #fff8f0 55%, #fff1e3 100%);
}

.hero-card--danger {
  background: linear-gradient(160deg, #ffffff 0%, #fff3f3 55%, #fbe7e7 100%);
}

.hero-card__eyebrow {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  line-height: 1.4;
  letter-spacing: 4rpx;
  color: #2f8f83;
  text-transform: uppercase;
}

.hero-card__title {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #123f3a;
}

.hero-card__summary {
  margin-top: 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #41504c;
}
